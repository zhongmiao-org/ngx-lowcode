/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "outDir": "./dist/out-tsc",
    "baseUrl": ".",
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "ngx-lowcode-core-types": ["./dist/ngx-lowcode-core-types"],
      "ngx-lowcode-core-utils": ["./dist/ngx-lowcode-core-utils"],
      "ngx-lowcode-core": ["./dist/ngx-lowcode-core"],
      "ngx-lowcode-datasource": ["./dist/ngx-lowcode-datasource"],
      "ngx-lowcode-i18n": ["./dist/ngx-lowcode-i18n"],
      "ngx-lowcode-designer": ["./dist/ngx-lowcode-designer"],
      "ngx-lowcode-materials": ["./dist/ngx-lowcode-materials"],
      "ngx-lowcode-meta-model": ["./dist/ngx-lowcode-meta-model"],
      "ngx-lowcode-puzzle-adapter": ["./dist/ngx-lowcode-puzzle-adapter"],
      "ngx-lowcode-renderer": ["./dist/ngx-lowcode-renderer"],
      "ngx-lowcode-testing": ["./dist/ngx-lowcode-testing"]
    },
    "esModuleInterop": true,
    "sourceMap": true,
    "declaration": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  }
}
