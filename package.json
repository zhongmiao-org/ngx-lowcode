{
  "name": "ngx-lowcode",
  "version": "0.1.0",
  "packageManager": "npm@11.4.2",
  "workspaces": [
    "projects/*"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve ngx-lowcode-demo --configuration offline",
    "start:demo:offline": "ng serve ngx-lowcode-demo --configuration offline",
    "start:demo:online": "ng serve ngx-lowcode-demo --configuration online",
    "build": "ng build ngx-lowcode-core-types && ng build ngx-lowcode-i18n && ng build ngx-lowcode-core-utils && ng build ngx-lowcode-meta-model && ng build ngx-lowcode-datasource && ng build ngx-lowcode-core && ng build ngx-lowcode-renderer && ng build ngx-lowcode-materials && ng build ngx-lowcode-designer && ng build ngx-lowcode-testing && ng build ngx-lowcode-puzzle-adapter",
    "build:demo:offline": "ng build ngx-lowcode-demo --configuration offline",
    "build:demo:online": "ng build ngx-lowcode-demo --configuration online",
    "build:libs": "ng build ngx-lowcode-core-types && ng build ngx-lowcode-i18n && ng build ngx-lowcode-core-utils && ng build ngx-lowcode-meta-model && ng build ngx-lowcode-datasource && ng build ngx-lowcode-core && ng build ngx-lowcode-renderer && ng build ngx-lowcode-materials && ng build ngx-lowcode-designer && ng build ngx-lowcode-testing && ng build ngx-lowcode-puzzle-adapter",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "watch": "npm run watch:designer",
    "watch:designer": "node scripts/watch-libs.mjs --designer",
    "watch:libs": "node scripts/watch-libs.mjs --all",
    "test": "ng test ngx-lowcode-core --watch=false && ng test ngx-lowcode-meta-model --watch=false && ng test ngx-lowcode-datasource --watch=false && ng test ngx-lowcode-renderer --watch=false && ng test ngx-lowcode-materials --watch=false && ng test ngx-lowcode-designer --watch=false && ng test ngx-lowcode-puzzle-adapter --watch=false",
    "lint": "npm run format:check",
    "version:check": "bash scripts/version-consistency.sh",
    "publish:all": "bash scripts/publish-all.sh",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:publish": "bash scripts/publish-all.sh",
    "release:status": "changeset status --verbose",
    "release:draft-notes": "node scripts/release/compose-draft-from-unreleased.mjs",
    "release:draft-notes:json": "node scripts/release/compose-draft-from-unreleased.mjs --json",
    "release:apply-batch-versions": "node scripts/release/apply-release-batch-versions.mjs",
    "release:publish-selected": "node scripts/release/publish-selected-packages.mjs",
    "release:finalize-unreleased": "node scripts/release/finalize-unreleased-changelogs.mjs",
    "release:next-version": "node -p \"require('./projects/ngx-lowcode/package.json').version\""
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.7",
    "@angular/cdk": "21.2.6",
    "@angular/common": "21.2.7",
    "@angular/compiler": "21.2.7",
    "@angular/core": "21.2.7",
    "@angular/forms": "21.2.7",
    "@angular/platform-browser": "21.2.7",
    "@angular/platform-browser-dynamic": "21.2.7",
    "@angular/router": "21.2.7",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "@tethys/cdk": "21.0.0",
    "@tethys/icons": "^1.4.23",
    "@zhongmiao/meta-lc-runtime-angular": "0.2.1",
    "ngx-tethys": "21.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.7",
    "@angular/cli": "21.2.7",
    "@angular/compiler-cli": "21.2.7",
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.29.7",
    "jsdom": "^29.0.2",
    "ng-packagr": "21.2.2",
    "prettier": "^3.8.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5"
  }
}
